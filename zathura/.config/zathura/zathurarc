# zathurarc — Catppuccin Mocha theme
# https://pwmt.org/projects/zathura/documentation/

# UI
set font "JetBrainsMono Nerd Font 11"
set window-title-basename true
set statusbar-basename true
set selection-clipboard clipboard
set adjust-open "best-fit"
set pages-per-row 1
set scroll-step 60
set scroll-full-overlap 0.01
set guioptions ""

# Recolor (light-on-dark) mode, off by default; toggle with the 'r' keybind
set recolor false
set recolor-keephue true
set recolor-reverse-video false

# Catppuccin Mocha colors
set default-bg               "#1e1e2e"
set default-fg               "#cdd6f4"

set statusbar-fg             "#cdd6f4"
set statusbar-bg             "#313244"

set inputbar-bg              "#1e1e2e"
set inputbar-fg              "#cdd6f4"

set notification-bg          "#1e1e2e"
set notification-fg          "#cdd6f4"
set notification-error-bg    "#1e1e2e"
set notification-error-fg    "#f38ba8"
set notification-warning-bg  "#1e1e2e"
set notification-warning-fg  "#fab387"

set completion-bg            "#313244"
set completion-fg            "#cdd6f4"
set completion-group-bg      "#1e1e2e"
set completion-group-fg      "#89b4fa"
set completion-highlight-bg  "#89b4fa"
set completion-highlight-fg  "#1e1e2e"

set index-bg                 "#1e1e2e"
set index-fg                 "#cdd6f4"
set index-active-bg          "#89b4fa"
set index-active-fg          "#1e1e2e"

set recolor-lightcolor       "#1e1e2e"
set recolor-darkcolor        "#cdd6f4"

set highlight-color          "#f9e2af"
set highlight-active-color   "#89b4fa"
set highlight-transparency   0.5

# Keybindings
map D toggle_page_mode
map r reload
map R rotate
map K zoom in
map J zoom out
map i recolor
